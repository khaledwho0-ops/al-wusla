{
  "appId": "com.alwusla.app",
  "appName": "AlWusla",
  "webDir": "dist",
  "server": {
    "cleartext": true,
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#0f172a",
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": true,
    "initialFocus": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#0f172a",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  }
}